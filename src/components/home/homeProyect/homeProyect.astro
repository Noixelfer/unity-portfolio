---
import HomeProjectCard from "./homeProyectCard.astro";
import { projects } from "../../../data/projectData.js";
---

<section class="relative z-10 pt-16 pb-10 md:pt-20">
  <h2
    class="text-3xl md:text-4xl font-bold text-white mb-12 mx-auto px-6 text-center text-shadow"
  >
    Featured Projects
  </h2>

  <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3 max-w-6xl mx-auto px-4">
    {projects.map((project) => <HomeProjectCard project={project} />)}
  </div>
  <div class="mt-12 flex justify-center">
    <a
      href="/projects"
      class="px-6 py-3 bg-primary hover:bg-secondary text-white font-semibold rounded-3xl transition-all duration-150
           drop-shadow-[2px_2px_0_#0debd8] active:translate-0.5 active:drop-shadow-none"
    >
      View All Projects
    </a>
  </div>
</section>
