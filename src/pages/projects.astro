---
import "../styles/projects.css";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/commons/hero/hero.astro";
import Banner from "../components/commons/banners/banner.astro";
import ProjectsIsland from "../components/projects/ProjectsIsland";
---

<Layout
  title="Projects | Paul Pop"
  description="Explore Unity projects Paul Pop has worked on, including shipped mobile simulation games, major updates, performance work, and technical systems."
>
  <Hero titulo="Projects" />

  <!-- Interactive projects section -->
    <section class="mt-10 mx-auto max-w-6xl px-6">
     <ProjectsIsland client:visible />
   </section>

  <Banner />
</Layout>
